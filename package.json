{
  "name": "wechat-pub",
  "displayName": "微信公众号助手",
  "description": "Markdown 编辑器，支持公众号格式预览、复制和发布",
  "version": "0.1.0",
  "publisher": "your-publisher",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wechatPub",
          "title": "微信公众号助手",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "wechatPub": [
        {
          "id": "wechatPub.sidebar",
          "name": "已发布草稿"
        }
      ]
    },
    "commands": [
      {
        "command": "wechatPub.preview",
        "title": "预览公众号格式"
      },
      {
        "command": "wechatPub.copyHtml",
        "title": "复制公众号 HTML"
      },
      {
        "command": "wechatPub.publish",
        "title": "发布到草稿箱"
      },
      {
        "command": "wechatPub.updateDraft",
        "title": "更新草稿"
      },
      {
        "command": "wechatPub.setTheme",
        "title": "切换主题"
      },
      {
        "command": "wechatPub.setPrimaryColor",
        "title": "设置主题色"
      },
      {
        "command": "wechatPub.toggleOption",
        "title": "切换选项"
      },
      {
        "command": "wechatPub.uploadImage",
        "title": "上传图片到公众号"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "wechatPub.preview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "wechatPub.uploadImage",
          "when": "editorLangId == markdown",
          "group": "wechatPub"
        },
        {
          "command": "wechatPub.publish",
          "when": "editorLangId == markdown",
          "group": "wechatPub"
        },
        {
          "command": "wechatPub.copyHtml",
          "when": "editorLangId == markdown",
          "group": "wechatPub"
        }
      ],
      "explorer/context": [
        {
          "command": "wechatPub.uploadImage",
          "when": "resourceFilename =~ /\\.png$|\\.jpg$|\\.jpeg$|\\.gif$|\\.webp$/",
          "group": "wechatPub"
        }
      ]
    },
    "configuration": {
      "title": "微信公众号助手",
      "properties": {
        "wechatPub.appId": {
          "type": "string",
          "default": "",
          "description": "公众号 AppID"
        },
        "wechatPub.appSecret": {
          "type": "string",
          "default": "",
          "description": "公众号 AppSecret"
        },
        "wechatPub.proxyOrigin": {
          "type": "string",
          "default": "",
          "description": "API 代理地址（可选）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "webpack",
    "watch": "webpack --watch",
    "build": "webpack --mode production"
  },
  "dependencies": {
    "front-matter": "^4.0.2",
    "highlight.js": "^11.9.0",
    "isomorphic-dompurify": "^2.36.0",
    "juice": "^10.0.0",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.91.0",
    "@vscode/vsce": "^2.22.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
